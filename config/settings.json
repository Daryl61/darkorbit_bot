            "green":  { "lower": [35, 80, 80],  "upper": [85, 255, 255] },
            "blue":   { "lower": [90, 50, 50],  "upper": [130, 255, 255] },
            "red_low":  { "lower": [0, 80, 80],   "upper": [10, 255, 255] },
            "red_high": { "lower": [170, 80, 80],  "upper": [180, 255, 255] }
        }
    },
    "navigator": {
        "click_delay_min": 0.4,
        "click_delay_max": 1.2,
        "move_delay_min": 1.5,
        "move_delay_max": 4.0,
        "random_walk_radius": 300,
        "collection_wait": 2.0
