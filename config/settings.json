{
    "screen_region": {
        "top": 0,
        "left": 0,
        "width": 1920,
        "height": 1080
    },
    "capture_fps": 10,
    "detection": {
        "template_threshold": 0.75,
        "color_detection_enabled": true,
        "nms_threshold": 30,
        "bonus_box_hsv": {
